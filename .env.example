# ===== pg17 service env example =====
# Core
PG17_API_TOKEN=
PG17_RETENTION_DAYS=7
PG17_AUDIT_LOG_PATH=/tmp/culture-escrow-pg17/audit.log.jsonl
PG17_IDEMPOTENCY_TTL_SECONDS=3600
PG17_IDEMPOTENCY_STORE=/tmp/culture-escrow-pg17/idempotency_store.json

# Runtime
PG17_HOST=127.0.0.1
PG17_PORT=8787
PG17_LOG_LEVEL=info

# Engine runtime
PG17_ENGINE_PYTHON=python3
PG17_ENGINE_SCRIPT=tools/pg17-engine/fill_page17_stub.py

# Escrow company fixed fields (required for real engine, do NOT hardcode in source)
PG17_ESCROW_COMPANY=
PG17_BY_NAME=
PG17_ADDRESS=
PG17_PHONE=
PG17_LICENSE=
PG17_COUNTER_OFFER_NUMBERS=one

# CORS (comma-separated allowed origins)
PG17_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:8081,http://localhost:8081
