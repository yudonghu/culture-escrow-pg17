# ===== pg17 service env example =====
# Core
PG17_API_TOKEN=
PG17_RETENTION_DAYS=7
PG17_AUDIT_LOG_PATH=/tmp/culture-escrow-pg17/audit.log.jsonl
PG17_IDEMPOTENCY_TTL_SECONDS=3600
PG17_IDEMPOTENCY_STORE=/tmp/culture-escrow-pg17/idempotency_store.json

# Runtime
PG17_HOST=127.0.0.1
PG17_PORT=8787
PG17_LOG_LEVEL=info

# Engine runtime
PG17_ENGINE_PYTHON=python3
PG17_ENGINE_SCRIPT=tools/pg17-engine/fill_page17_stub.py
