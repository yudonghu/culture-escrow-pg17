# staging
PG17_API_TOKEN=replace-with-staging-token
PG17_RETENTION_DAYS=7
PG17_AUDIT_LOG_PATH=/var/log/pg17/staging-audit.log.jsonl
PG17_IDEMPOTENCY_TTL_SECONDS=3600
PG17_IDEMPOTENCY_STORE=/var/lib/pg17/staging-idempotency.json
PG17_HOST=0.0.0.0
PG17_PORT=8787
PG17_LOG_LEVEL=info

# Engine runtime
PG17_ENGINE_PYTHON=python3
PG17_ENGINE_SCRIPT=tools/pg17-engine/fill_page17_stub.py

# Escrow company fixed fields (required for real engine)
PG17_ESCROW_COMPANY=
PG17_BY_NAME=
PG17_ADDRESS=
PG17_PHONE=
PG17_LICENSE=
PG17_COUNTER_OFFER_NUMBERS=one

# CORS (comma-separated allowed origins)
PG17_CORS_ORIGINS=https://staging.hydenluc.com,http://localhost:8080
