# production
PG17_API_TOKEN=replace-with-prod-token
PG17_RETENTION_DAYS=7
PG17_AUDIT_LOG_PATH=/var/log/pg17/prod-audit.log.jsonl
PG17_IDEMPOTENCY_TTL_SECONDS=7200
PG17_IDEMPOTENCY_STORE=/var/lib/pg17/prod-idempotency.json
PG17_HOST=0.0.0.0
PG17_PORT=8787
PG17_LOG_LEVEL=warning

# Engine runtime
PG17_ENGINE_PYTHON=python3
PG17_ENGINE_SCRIPT=packages/pg17-fill-engine/fill_page17_real.py

# Escrow company fixed fields (required for real engine)
PG17_ESCROW_COMPANY=
PG17_BY_NAME=
PG17_ADDRESS=
PG17_PHONE=
PG17_LICENSE=
PG17_COUNTER_OFFER_NUMBERS=one

# CORS (comma-separated allowed origins)
PG17_CORS_ORIGINS=https://portal.cultureescrow.com,https://app.hydenluc.com

# S3 permanent storage (EC2 IAM role must have s3:PutObject on this bucket)
PG17_S3_BUCKET=culture-escrow-pg17-outputs
PG17_S3_REGION=us-west-1

# Monitoring alerts — Gmail App Password (not account password)
PG17_ALERT_EMAIL=hydenluc@gmail.com
PG17_ALERT_SMTP_USER=hydenluc@gmail.com
PG17_ALERT_SMTP_PASSWORD=replace-with-gmail-app-password
PG17_DISK_WARN_GB=2.0
PG17_MONITOR_FAIL_THRESHOLD=3
